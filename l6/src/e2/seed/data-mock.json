{
  "api_structure": {
    "registrar": {
      "method": "POST",
      "endpoint": "/estudiantes",
      "body": {
        "matricula": "string",
        "nombre": "string",
        "carrera": "string",
        "edad": "integer",
        "email": "string",
        "telefono": "string",
        "matriculado": "boolean",
        "semestres": "integer",
        "estado": "string"
      },
      "response_success": {
        "ok": true
      }
    },
    "consultar": {
      "method": "GET",
      "endpoint": "/estudiantes",
      "response_success": [
        {
          "id": "integer",
          "matricula": "string",
          "nombre": "string",
          "carrera": "string",
          "edad": "integer",
          "email": "string",
          "telefono": "string",
          "matriculado": "boolean",
          "semestres": "integer",
          "estado": "string"
        }
      ]
    },
    "actualizar": {
      "method": "PUT",
      "endpoint": "/estudiantes/<id>",
      "body": {
        "matricula": "string (opcional)",
        "nombre": "string (opcional)",
        "carrera": "string (opcional)",
        "edad": "integer (opcional)",
        "email": "string (opcional)",
        "telefono": "string (opcional)",
        "matriculado": "boolean (opcional)",
        "semestres": "integer (opcional)",
        "estado": "string (opcional)"
      },
      "response_success": {
        "actualizado": true
      }
    },
    "eliminar": {
      "method": "DELETE",
      "endpoint": "/estudiantes/<id>",
      "response_success": {
        "eliminado": true
      }
    }
  },
  
