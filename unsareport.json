{
  "template": "multi-lab",
  "mode": "multi",
  "sessions": [
    "l4",
    "l5",
    "l6",
    "l7",
    "l8",
    "l9",
    "l10",
    "l11"
  ],
  "capture": {
    "columns": 150,
    "freezeFlags": [
      "--font.family",
      "CaskaydiaMono Nerd Font",
      "--theme",
      "catppuccin-mocha"
    ],
    "prompt": "❯ ",
    "colors": {
      "args": "38;5;217",
      "command": "38;5;111",
      "prompt": "38;5;114",
      "reset": "0"
    }
  },
  "prepare": {
    "input": {
      "srcDir": "src",
      "reportFile": "report.typ"
    },
    "output": {
      "submissionDir": "submission",
      "fileTemplate": "{output_type} {lab_number} - {course_name} - {members_abbr_list}",
      "reportWord": "Informe",
      "codeWord": "Código Fuente"
    }
  }
}
