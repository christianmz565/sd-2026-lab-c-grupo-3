{
  "multiLab": true,
  "sessions": [
    "l4",
    "l5"
  ],
  "capture": {
    "freezeFlags": [
      "--font.family",
      "CaskaydiaMono Nerd Font",
      "--width",
      "1000",
      "--theme",
      "catppuccin-mocha"
    ],
    "prompt": "❯ ",
    "colors": {
      "args": "38;5;217",
      "command": "38;5;111",
      "prompt": "38;5;114",
      "reset": "0"
    }
  },
  "prepare": {
    "input": {
      "srcDir": "src",
      "reportFile": "report.typ"
    },
    "output": {
      "submissionDir": "submission",
      "fileTemplate": "{output_type} {lab_number} - {course_name} - {members_abbr_list}",
      "reportWord": "Informe",
      "codeWord": "Código Fuente"
    }
  }
}
